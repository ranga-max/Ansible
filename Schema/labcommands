REGISTER RULES

SCHEMA=$(curl -s \
  --cacert ca.crt \
  --cert   client.crt \
  --key    client.key \
  -u rang:rang-secret \
  -H "Accept: application/vnd.schemaregistry.v1+json" \
  "https://kafka-0.rrchakdc2.ans.test.io:8081/subjects/customer-value/versions/latest" \
  | jq '.schema')


# Attach Rule Set
curl  \
  --cacert ca.crt \
  --cert   client.crt \
  --key    client.key \
  -u rang:rang-secret \
  -H "Content-Type: application/vnd.schemaregistry.v1+json" \
  --data @- \
  "https://kafka-0.rrchakdc2.ans.test.io:8081/subjects/customer-value/versions" <<EOF
{
  "schemaType": "AVRO",
  "schema": $SCHEMA,
  "ruleSet": {
    "domainRules": [
      {
        "name": "encryptPII",
        "kind": "TRANSFORM",
        "type": "ENCRYPT",
        "mode": "WRITEREAD",
        "tags": ["PII"],
        "params": {
          "encrypt.kek.name": "customer-ssn-kek",
          "encrypt.kms.type": "aws-kms",
          "encrypt.kms.key.id": "arn:aws:kms:us-east-1:xxxxxxxx:key/yyyyyy"
        },
        "onFailure": "ERROR,NONE"
      }
    ]
  }
}
EOF


# Check Ruleset
curl -s \
  --cacert ca.crt \
  --cert   client.crt \
  --key    client.key \
  -u rang:rang-secret \
  -H "Accept: application/vnd.schemaregistry.v1+json" \
  "https://kafka-0.rrchakdc2.ans.test.io:8081/subjects/customer-value/versions/latest" \
| jq '.ruleSet.domainRules[] | select(.type=="ENCRYPT")'


